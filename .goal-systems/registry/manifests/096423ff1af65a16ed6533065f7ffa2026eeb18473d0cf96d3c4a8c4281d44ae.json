        "selector": {
          "type": "local",
          "path": "poc/dependency-upgrade-instrumented/policy.md"
        }
      },
      {
        "name": "mutation-policy",
        "provider": "declared",
        "contract": "goal-system.policy/v1",
        "selector": {
          "type": "exact",
